    "miniflare": "^4.20260630.0",
    "playwright": "^1.61.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1"
  }
